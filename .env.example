# NexaSecure AI — environment configuration template.
# Copy this file to ".env" and adjust. NEVER commit the real .env.

# ---- Backend ----
NEXA_ENV=development                 # development | staging | production
NEXA_API_HOST=0.0.0.0
NEXA_API_PORT=8000
NEXA_LOG_LEVEL=INFO

# ---- Security ----
# Generate a real secret for anything beyond local dev:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
NEXA_JWT_SECRET=dev-only-change-me
NEXA_JWT_EXPIRE_MINUTES=60

# ---- Database ----
# SQLite for development (zero setup). Swap to a Postgres URL later.
NEXA_DATABASE_URL=sqlite:///./nexasecure.sqlite3

# ---- Sensors ----
# OBD source: "none" stays disconnected (honest default — engine data is never simulated),
# "serial" is a REAL read-only ELM327 adapter (needs `pip install -r requirements-obd.txt`).
NEXA_OBD_SOURCE=none                  # none | serial
NEXA_OBD_POLL_SECONDS=2
# Real serial adapter settings (only used when OBD source/mode is "serial"):
#   "auto" scans for the port; otherwise COM3, /dev/ttyUSB0, or the ELM327-emulator pseudo-tty.
#   Baudrate blank = auto-detect (ELM327 is typically 38400 or 9600).
NEXA_OBD_SERIAL_PORT=auto
# NEXA_OBD_BAUDRATE=38400
NEXA_OBD_CONNECT_TIMEOUT=30

# ---- Cameras ----
# Real detection runs in the browser (MediaPipe / OpenCV.js) and is pushed to the /driver and
# /road ingest endpoints. "none" leaves the backend idle until those live frames arrive;
# "webcam" is an optional server-side OpenCV source for headless/dev use.
NEXA_DRIVER_CAM_SOURCE=none          # none | webcam
NEXA_DRIVER_FPS=5
# Road-facing (traffic signs / hazard / lane / forward collision) — browser detection only.
NEXA_SIGN_SOURCE=none                # none
NEXA_SIGN_FPS=4
NEXA_ROAD_SOURCE=none                # none
NEXA_ROAD_FPS=5

# ---- Privacy (defaults are the safe choice) ----
NEXA_CLOUD_SYNC=false
NEXA_STORE_INCIDENT_CLIPS=false
NEXA_ANONYMIZED_ANALYTICS=false
